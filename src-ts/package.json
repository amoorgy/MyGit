{
  "name": "mygit",
  "version": "0.1.0",
  "type": "module",
  "description": "AI-powered Git CLI agent — React/Ink + LangChain edition",
  "bin": {
    "mygit": "./dist/index.js",
    "git-brain": "./dist/git-brain.js"
