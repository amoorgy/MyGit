    "@langchain/openai": "^0.3.0",
    "chalk": "^5.4.0",
    "commander": "^12.1.0",
    "diff": "^8.0.3",
    "execa": "^9.5.0",
    "figures": "^6.1.0",
    "ink": "^5.1.0",
    "ink-markdown": "^1.0.4",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
